{
  "name": "elemintz-pc",
  "version": "0.1.5",
  "description": "EleMintz desktop card game",
  "private": true,
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "multiplayer:start": "node src/multiplayer/server.js",
    "multiplayer:dev": "nodemon --watch src/multiplayer --ext js --exec node src/multiplayer/server.js",
    "test": "node --test",
    "dist:win": "powershell -ExecutionPolicy Bypass -File build/make-win-installer.ps1",
    "pack:win": "electron-builder --dir --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "build": {
    "appId": "com.elemintz.pc",
    "productName": "EleMintz",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "files": [
      "assets/**/*",
      "src/**/*",
      "package.json"
    ]
  }
}
